{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "target": "ES2020",
    "strict": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "playwright.openwrt.config.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.openwrt-component.config.ts"
  ]
}
