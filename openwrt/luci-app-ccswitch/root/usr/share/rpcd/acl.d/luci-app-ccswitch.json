{
	"luci-app-ccswitch": {
		"description": "Grant access to CC Switch Proxy configuration",
		"read": {
			"uci": ["ccswitch"],
			"ubus": {
				"service": ["list"],
				"ccswitch": [
					"list_providers",
					"get_provider",
					"get_active_provider",
					"get_runtime_status",
					"get_app_runtime_status"
				]
			}
		},
		"write": {
			"uci": ["ccswitch"],
			"ubus": {
				"ccswitch": [
					"upsert_provider",
					"upsert_active_provider",
					"delete_provider",
					"activate_provider",
					"restart_service"
				]
			}
		}
	}
}
