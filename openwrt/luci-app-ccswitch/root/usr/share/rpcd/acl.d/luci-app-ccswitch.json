{
	"luci-app-ccswitch": {
		"description": "Grant access to CC Switch Proxy configuration",
		"read": {
			"uci": ["ccswitch"],
			"ubus": {
				"service": ["list"],
				"ccswitch": [
					"list_providers",
					"get_provider",
					"get_provider_failover",
					"get_active_provider",
					"get_host_config",
					"get_runtime_status",
					"get_app_runtime_status",
					"get_usage_summary",
					"get_provider_stats",
					"get_available_failover_providers"
				]
			}
		},
		"write": {
			"uci": ["ccswitch"],
			"ubus": {
				"ccswitch": [
					"upsert_provider",
					"upsert_active_provider",
					"delete_provider",
					"activate_provider",
					"add_to_failover_queue",
					"remove_from_failover_queue",
					"set_auto_failover_enabled",
					"reorder_failover_queue",
					"set_max_retries",
					"set_host_config",
					"restart_service"
				]
			}
		}
	}
}
