'use strict';

import { popen } from 'fs';
import { cursor } from 'uci';

const DATA_DIR = '/etc/cc-switch';
const BINARY = '/usr/bin/cc-switch';
const INIT_SCRIPT = '/etc/init.d/ccswitch';
const DEFAULT_APP = 'claude';

function shellquote(value) {
	let string = value;
	if (string == null)
		string = '';

	return `'${replace(string, "'", "'\\''")}'`;
}

function daemonCommand(args) {
	return `env CC_SWITCH_DATA_DIR=${shellquote(DATA_DIR)} ${shellquote(BINARY)} ${args} 2>&1`;
}

function normalizeApp(app) {
	let value = app;

	if (!value)
		value = DEFAULT_APP;

	value = trim(value);

	if (value != 'claude' && value != 'codex' && value != 'gemini')
		return null;

	return value;
}

function runReadCommand(command) {
	let proc = popen(command, 'r');

	if (!proc)
		return { ok: false, error: 'failed to start command' };

	let output = proc.read('all');
	if (output == null)
		output = '';
	let code = proc.close();

	if (code !== 0)
		return {
			ok: false,
			code: code,
			error: output || 'command failed'
		};

	return {
		ok: true,
		code: code,
		output: output
	};
}

function commandFailure(result) {
	return {
		ok: false,
		code: result.code,
		error: result.error ? result.error : (result.output ? result.output : 'command failed')
	};
}

function commandSuccess(result) {
	let parsed = json(result.output);

	if (parsed == null)
		return {
			ok: false,
			code: result.code,
			error: 'invalid JSON from daemon'
		};

	parsed.ok = true;

	return parsed;
}

function runProviderCommand(command) {
	let result = runReadCommand(command);

	if (!result.ok)
		return commandFailure(result);

	return commandSuccess(result);
}

function runProvidersCommand(command) {
	let result = runReadCommand(command);

	if (!result.ok)
		return commandFailure(result);

	return commandSuccess(result);
}

function runResultCommand(command) {
	let result = runReadCommand(command);

	if (!result.ok)
		return commandFailure(result);

	return commandSuccess(result);
}

function runStatusCommand(command) {
	let result = runReadCommand(command);

	if (!result.ok)
		return commandFailure(result);

	return commandSuccess(result);
}

function requireProviderId(providerId) {
	if (!providerId)
		return { ok: false, error: 'provider_id is required' };

	return null;
}

function normalizeEnabled(enabled) {
	if (enabled === true || enabled === 1 || enabled === '1' || enabled === 'true')
		return true;

	if (enabled === false || enabled === 0 || enabled === '0' || enabled === 'false')
		return false;

	return null;
}

function hostConfigCursor() {
	let ctx = cursor();

	if (!ctx)
		return null;

	ctx.load('ccswitch');

	return ctx;
}

function hostConfigViewFromCursor(ctx) {
	let enabled = normalizeEnabled(ctx.get('ccswitch', 'main', 'enabled'));

	return {
		enabled: enabled === true,
		listenAddr: ctx.get('ccswitch', 'main', 'listen_addr') || '',
		listenPort: ctx.get('ccswitch', 'main', 'listen_port') || '',
		httpProxy: ctx.get('ccswitch', 'main', 'http_proxy') || '',
		httpsProxy: ctx.get('ccswitch', 'main', 'https_proxy') || '',
		logLevel: ctx.get('ccswitch', 'main', 'log_level') || 'info'
	};
}

function hostConfigSuccess(ctx) {
	let view = hostConfigViewFromCursor(ctx);

	view.ok = true;

	return view;
}

function getHostConfig() {
	let ctx = hostConfigCursor();

	if (!ctx)
		return { ok: false, error: 'failed to open UCI cursor' };

	return hostConfigSuccess(ctx);
}

function setHostConfig(host) {
	let ctx = hostConfigCursor();
	let current;
	let enabled;

	if (!ctx)
		return { ok: false, error: 'failed to open UCI cursor' };

	current = hostConfigViewFromCursor(ctx);
	enabled = normalizeEnabled(host ? host.enabled : current.enabled);

	if (enabled == null)
		enabled = current.enabled;

	if (!ctx.set('ccswitch', 'main', 'enabled', enabled ? '1' : '0') ||
		!ctx.set('ccswitch', 'main', 'listen_addr', host && host.listenAddr != null ? '' + host.listenAddr : current.listenAddr) ||
		!ctx.set('ccswitch', 'main', 'listen_port', host && host.listenPort != null ? '' + host.listenPort : current.listenPort) ||
		!ctx.set('ccswitch', 'main', 'http_proxy', host && host.httpProxy != null ? '' + host.httpProxy : current.httpProxy) ||
		!ctx.set('ccswitch', 'main', 'https_proxy', host && host.httpsProxy != null ? '' + host.httpsProxy : current.httpsProxy) ||
		!ctx.set('ccswitch', 'main', 'log_level', host && host.logLevel != null ? '' + host.logLevel : current.logLevel))
		return { ok: false, error: 'failed to update ccswitch.main' };

	if (!ctx.commit('ccswitch'))
		return { ok: false, error: 'failed to commit ccswitch config' };

	return hostConfigSuccess(ctx);
}

function listProviders(app) {
	let normalizedApp = normalizeApp(app);

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runProvidersCommand(daemonCommand(`openwrt ${shellquote(normalizedApp)} list-providers`));
}

function getProvider(app, providerId) {
	let normalizedApp = normalizeApp(app);
	let missing = requireProviderId(providerId);
	if (missing)
		return missing;

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runProviderCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} get-provider ${shellquote(providerId)}`)
	);
}

function getProviderFailover(app, providerId) {
	let normalizedApp = normalizeApp(app);
	let missing = requireProviderId(providerId);
	if (missing)
		return missing;

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runStatusCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} get-provider-failover ${shellquote(providerId)}`)
	);
}

function getActiveProvider(app) {
	let normalizedApp = normalizeApp(app);

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runProviderCommand(daemonCommand(`openwrt ${shellquote(normalizedApp)} get-active-provider`));
}

function getRuntimeStatus() {
	return runStatusCommand(daemonCommand('openwrt get-runtime-status'));
}

function getAppRuntimeStatus(app) {
	let normalizedApp = normalizeApp(app);

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runStatusCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} get-runtime-status`)
	);
}

function getAvailableFailoverProviders(app) {
	let normalizedApp = normalizeApp(app);

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runProvidersCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} get-available-failover-providers`)
	);
}

function upsertProvider(app, providerId, provider) {
	let normalizedApp = normalizeApp(app);

	if (!provider)
		return { ok: false, error: 'provider payload is required' };

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	let providerJson = sprintf('%J', provider);
	let command = providerId
		? daemonCommand(`openwrt ${shellquote(normalizedApp)} upsert-provider ${shellquote(providerId)}`)
		: daemonCommand(`openwrt ${shellquote(normalizedApp)} upsert-provider`);

	return runProviderCommand(
		`printf '%s\n' ${shellquote(providerJson)} | ${command}`
	);
}

function upsertActiveProvider(app, provider) {
	let normalizedApp = normalizeApp(app);

	if (!provider)
		return { ok: false, error: 'provider payload is required' };

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	let providerJson = sprintf('%J', provider);

	return runProviderCommand(
		`printf '%s\n' ${shellquote(providerJson)} | ${daemonCommand(`openwrt ${shellquote(normalizedApp)} upsert-active-provider`)}`
	);
}

function deleteProvider(app, providerId) {
	let normalizedApp = normalizeApp(app);
	let missing = requireProviderId(providerId);
	if (missing)
		return missing;

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runResultCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} delete-provider ${shellquote(providerId)}`)
	);
}

function activateProvider(app, providerId) {
	let normalizedApp = normalizeApp(app);
	let missing = requireProviderId(providerId);
	if (missing)
		return missing;

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runProviderCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} activate-provider ${shellquote(providerId)}`)
	);
}

function addToFailoverQueue(app, providerId) {
	let normalizedApp = normalizeApp(app);
	let missing = requireProviderId(providerId);
	if (missing)
		return missing;

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runStatusCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} add-to-failover-queue ${shellquote(providerId)}`)
	);
}

function removeFromFailoverQueue(app, providerId) {
	let normalizedApp = normalizeApp(app);
	let missing = requireProviderId(providerId);
	if (missing)
		return missing;

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runStatusCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} remove-from-failover-queue ${shellquote(providerId)}`)
	);
}

function reorderFailoverQueue(app, providerIds) {
	let normalizedApp = normalizeApp(app);

	if (!providerIds || length(providerIds) === 0)
		return { ok: false, error: 'provider_ids must be a non-empty array' };

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	let providerIdsJson = sprintf('%J', providerIds);

	return runStatusCommand(
		`printf '%s\n' ${shellquote(providerIdsJson)} | ${daemonCommand(`openwrt ${shellquote(normalizedApp)} reorder-failover-queue`)}`
	);
}

function setAutoFailoverEnabled(app, enabled) {
	let normalizedApp = normalizeApp(app);
	let normalizedEnabled = normalizeEnabled(enabled);

	if (normalizedEnabled == null)
		return { ok: false, error: 'enabled must be a boolean' };

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runStatusCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} set-auto-failover-enabled ${shellquote(normalizedEnabled ? 'true' : 'false')}`)
	);
}

function setMaxRetries(app, value) {
	let normalizedApp = normalizeApp(app);

	if (value == null || value === '')
		return { ok: false, error: 'value is required' };

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runStatusCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} set-max-retries ${shellquote(value)}`)
	);
}

function restartService() {
	let result = runReadCommand(`${shellquote(INIT_SCRIPT)} restart`);

	return {
		ok: result.ok,
		code: result.code,
		output: result.output ? result.output : '',
		error: result.error
	};
}

return {
	ccswitch: {
		list_providers: {
			args: {
				app: 'claude'
			},

			call: function(request) {
				return listProviders(request.args.app);
			}
		},

		get_provider: {
			args: {
				app: 'claude',
				provider_id: 'provider-id'
			},

			call: function(request) {
				return getProvider(request.args.app, request.args.provider_id);
			}
		},

		get_provider_failover: {
			args: {
				app: 'claude',
				provider_id: 'provider-id'
			},

			call: function(request) {
				return getProviderFailover(request.args.app, request.args.provider_id);
			}
		},

		get_active_provider: {
			args: {
				app: 'claude'
			},

			call: function(request) {
				return getActiveProvider(request.args.app);
			}
		},

		get_runtime_status: {
			call: function() {
				return getRuntimeStatus();
			}
		},

		get_host_config: {
			call: function() {
				return getHostConfig();
			}
		},

		get_app_runtime_status: {
			args: {
				app: 'claude'
			},

			call: function(request) {
				return getAppRuntimeStatus(request.args.app);
			}
		},

		get_available_failover_providers: {
			args: {
				app: 'claude'
			},

			call: function(request) {
				return getAvailableFailoverProviders(request.args.app);
			}
		},

		get_available_providers_for_failover: {
			args: {
				app: 'claude'
			},

			call: function(request) {
				return getAvailableFailoverProviders(request.args.app);
			}
		},

		upsert_provider: {
			args: {
				app: 'claude',
				provider_id: 'provider-id',
				provider: {}
			},

			call: function(request) {
				return upsertProvider(request.args.app, request.args.provider_id, request.args.provider);
			}
		},

		upsert_active_provider: {
			args: {
				app: 'claude',
				provider: {}
			},

			call: function(request) {
				return upsertActiveProvider(request.args.app, request.args.provider);
			}
		},

		delete_provider: {
			args: {
				app: 'claude',
				provider_id: 'provider-id'
			},

			call: function(request) {
				return deleteProvider(request.args.app, request.args.provider_id);
			}
		},

		activate_provider: {
			args: {
				app: 'claude',
				provider_id: 'provider-id'
			},

			call: function(request) {
				return activateProvider(request.args.app, request.args.provider_id);
			}
		},

		add_to_failover_queue: {
			args: {
				app: 'claude',
				provider_id: 'provider-id'
			},

			call: function(request) {
				return addToFailoverQueue(request.args.app, request.args.provider_id);
			}
		},

		remove_from_failover_queue: {
			args: {
				app: 'claude',
				provider_id: 'provider-id'
			},

			call: function(request) {
				return removeFromFailoverQueue(request.args.app, request.args.provider_id);
			}
		},

		reorder_failover_queue: {
			args: {
				app: 'claude',
				provider_ids: [ 'provider-id' ]
			},

			call: function(request) {
				return reorderFailoverQueue(request.args.app, request.args.provider_ids);
			}
		},

		set_auto_failover_enabled: {
			args: {
				app: 'claude',
				enabled: true
			},

			call: function(request) {
				return setAutoFailoverEnabled(request.args.app, request.args.enabled);
			}
		},

		set_max_retries: {
			args: {
				app: 'claude',
				value: 3
			},

			call: function(request) {
				return setMaxRetries(request.args.app, request.args.value);
			}
		},

		set_host_config: {
			args: {
				host: {}
			},

			call: function(request) {
				return setHostConfig(request.args.host);
			}
		},

		restart_service: {
			call: function() {
				return restartService();
			}
		}
	}
};
