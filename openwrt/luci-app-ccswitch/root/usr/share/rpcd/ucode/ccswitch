'use strict';

import { popen } from 'fs';

const DATA_DIR = '/etc/cc-switch';
const BINARY = '/usr/bin/cc-switch';
const INIT_SCRIPT = '/etc/init.d/ccswitch';

function shellquote(value) {
	let string = value;
	if (string == null)
		string = '';

	return `'${replace(string, "'", "'\\''")}'`;
}

function daemonCommand(args) {
	return `env CC_SWITCH_DATA_DIR=${shellquote(DATA_DIR)} ${shellquote(BINARY)} ${args} 2>&1`;
}

function runReadCommand(command) {
	let proc = popen(command, 'r');

	if (!proc)
		return { ok: false, error: 'failed to start command' };

	let output = proc.read('all');
	if (output == null)
		output = '';
	let code = proc.close();

	if (code !== 0)
		return {
			ok: false,
			code: code,
			error: output || 'command failed'
		};

	return {
		ok: true,
		code: code,
		output: output
	};
}

function commandFailure(result) {
	return {
		ok: false,
		code: result.code,
		error: result.error ? result.error : (result.output ? result.output : 'command failed')
	};
}

function runProviderCommand(command) {
	let result = runReadCommand(command);

	if (!result.ok)
		return commandFailure(result);

	return {
		ok: true,
		provider_json: result.output
	};
}

function runProvidersCommand(command) {
	let result = runReadCommand(command);

	if (!result.ok)
		return commandFailure(result);

	return {
		ok: true,
		providers_json: result.output
	};
}

function runResultCommand(command) {
	let result = runReadCommand(command);

	if (!result.ok)
		return commandFailure(result);

	return {
		ok: true,
		result_json: result.output
	};
}

function requireProviderId(providerId) {
	if (!providerId)
		return { ok: false, error: 'provider_id is required' };

	return null;
}

function listProviders() {
	return runProvidersCommand(daemonCommand('openwrt list-providers'));
}

function getProvider(providerId) {
	let missing = requireProviderId(providerId);
	if (missing)
		return missing;

	return runProviderCommand(
		daemonCommand(`openwrt get-provider ${shellquote(providerId)}`)
	);
}

function getActiveProvider() {
	return runProviderCommand(daemonCommand('openwrt get-active-provider'));
}

function upsertProvider(providerId, provider) {
	if (!provider)
		return { ok: false, error: 'provider payload is required' };

	let providerJson = sprintf('%J', provider);
	let command = providerId
		? daemonCommand(`openwrt upsert-provider ${shellquote(providerId)}`)
		: daemonCommand('openwrt upsert-provider');

	return runProviderCommand(
		`printf '%s\n' ${shellquote(providerJson)} | ${command}`
	);
}

function upsertActiveProvider(provider) {
	if (!provider)
		return { ok: false, error: 'provider payload is required' };

	let providerJson = sprintf('%J', provider);

	return runProviderCommand(
		`printf '%s\n' ${shellquote(providerJson)} | ${daemonCommand('openwrt upsert-active-provider')}`
	);
}

function deleteProvider(providerId) {
	let missing = requireProviderId(providerId);
	if (missing)
		return missing;

	return runResultCommand(
		daemonCommand(`openwrt delete-provider ${shellquote(providerId)}`)
	);
}

function activateProvider(providerId) {
	let missing = requireProviderId(providerId);
	if (missing)
		return missing;

	return runProviderCommand(
		daemonCommand(`openwrt activate-provider ${shellquote(providerId)}`)
	);
}

function restartService() {
	let result = runReadCommand(`${shellquote(INIT_SCRIPT)} restart`);

	return {
		ok: result.ok,
		code: result.code,
		output: result.output ? result.output : '',
		error: result.error
	};
}

return {
	ccswitch: {
		list_providers: {
			call: function() {
				return listProviders();
			}
		},

		get_provider: {
			args: {
				provider_id: {}
			},

			call: function(request) {
				return getProvider(request.args.provider_id);
			}
		},

		get_active_provider: {
			call: function() {
				return getActiveProvider();
			}
		},

		upsert_provider: {
			args: {
				provider_id: {},
				provider: {}
			},

			call: function(request) {
				return upsertProvider(request.args.provider_id, request.args.provider);
			}
		},

		upsert_active_provider: {
			args: {
				provider: {}
			},

			call: function(request) {
				return upsertActiveProvider(request.args.provider);
			}
		},

		delete_provider: {
			args: {
				provider_id: {}
			},

			call: function(request) {
				return deleteProvider(request.args.provider_id);
			}
		},

		activate_provider: {
			args: {
				provider_id: {}
			},

			call: function(request) {
				return activateProvider(request.args.provider_id);
			}
		},

		restart_service: {
			call: function() {
				return restartService();
			}
		}
	}
};
