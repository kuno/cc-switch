'use strict';

import { popen } from 'fs';

const DATA_DIR = '/etc/cc-switch';
const BINARY = '/usr/bin/cc-switch';
const INIT_SCRIPT = '/etc/init.d/ccswitch';
const DEFAULT_APP = 'claude';

function shellquote(value) {
	let string = value;
	if (string == null)
		string = '';

	return `'${replace(string, "'", "'\\''")}'`;
}

function daemonCommand(args) {
	return `env CC_SWITCH_DATA_DIR=${shellquote(DATA_DIR)} ${shellquote(BINARY)} ${args} 2>&1`;
}

function normalizeApp(app) {
	let value = app;

	if (!value)
		value = DEFAULT_APP;

	value = trim(value);

	if (value != 'claude' && value != 'codex' && value != 'gemini')
		return null;

	return value;
}

function runReadCommand(command) {
	let proc = popen(command, 'r');

	if (!proc)
		return { ok: false, error: 'failed to start command' };

	let output = proc.read('all');
	if (output == null)
		output = '';
	let code = proc.close();

	if (code !== 0)
		return {
			ok: false,
			code: code,
			error: output || 'command failed'
		};

	return {
		ok: true,
		code: code,
		output: output
	};
}

function commandFailure(result) {
	return {
		ok: false,
		code: result.code,
		error: result.error ? result.error : (result.output ? result.output : 'command failed')
	};
}

function runProviderCommand(command) {
	let result = runReadCommand(command);

	if (!result.ok)
		return commandFailure(result);

	return {
		ok: true,
		provider_json: result.output
	};
}

function runProvidersCommand(command) {
	let result = runReadCommand(command);

	if (!result.ok)
		return commandFailure(result);

	return {
		ok: true,
		providers_json: result.output
	};
}

function runResultCommand(command) {
	let result = runReadCommand(command);

	if (!result.ok)
		return commandFailure(result);

	return {
		ok: true,
		result_json: result.output
	};
}

function runStatusCommand(command) {
	let result = runReadCommand(command);

	if (!result.ok)
		return commandFailure(result);

	return {
		ok: true,
		status_json: result.output
	};
}

function requireProviderId(providerId) {
	if (!providerId)
		return { ok: false, error: 'provider_id is required' };

	return null;
}

function listProviders(app) {
	let normalizedApp = normalizeApp(app);

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runProvidersCommand(daemonCommand(`openwrt ${shellquote(normalizedApp)} list-providers`));
}

function getProvider(app, providerId) {
	let normalizedApp = normalizeApp(app);
	let missing = requireProviderId(providerId);
	if (missing)
		return missing;

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runProviderCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} get-provider ${shellquote(providerId)}`)
	);
}

function getActiveProvider(app) {
	let normalizedApp = normalizeApp(app);

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runProviderCommand(daemonCommand(`openwrt ${shellquote(normalizedApp)} get-active-provider`));
}

function getRuntimeStatus() {
	return runStatusCommand(daemonCommand('openwrt get-runtime-status'));
}

function getAppRuntimeStatus(app) {
	let normalizedApp = normalizeApp(app);

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runStatusCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} get-runtime-status`)
	);
}

function upsertProvider(app, providerId, provider) {
	let normalizedApp = normalizeApp(app);

	if (!provider)
		return { ok: false, error: 'provider payload is required' };

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	let providerJson = sprintf('%J', provider);
	let command = providerId
		? daemonCommand(`openwrt ${shellquote(normalizedApp)} upsert-provider ${shellquote(providerId)}`)
		: daemonCommand(`openwrt ${shellquote(normalizedApp)} upsert-provider`);

	return runProviderCommand(
		`printf '%s\n' ${shellquote(providerJson)} | ${command}`
	);
}

function upsertActiveProvider(app, provider) {
	let normalizedApp = normalizeApp(app);

	if (!provider)
		return { ok: false, error: 'provider payload is required' };

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	let providerJson = sprintf('%J', provider);

	return runProviderCommand(
		`printf '%s\n' ${shellquote(providerJson)} | ${daemonCommand(`openwrt ${shellquote(normalizedApp)} upsert-active-provider`)}`
	);
}

function deleteProvider(app, providerId) {
	let normalizedApp = normalizeApp(app);
	let missing = requireProviderId(providerId);
	if (missing)
		return missing;

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runResultCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} delete-provider ${shellquote(providerId)}`)
	);
}

function activateProvider(app, providerId) {
	let normalizedApp = normalizeApp(app);
	let missing = requireProviderId(providerId);
	if (missing)
		return missing;

	if (!normalizedApp)
		return { ok: false, error: 'unsupported app' };

	return runProviderCommand(
		daemonCommand(`openwrt ${shellquote(normalizedApp)} activate-provider ${shellquote(providerId)}`)
	);
}

function restartService() {
	let result = runReadCommand(`${shellquote(INIT_SCRIPT)} restart`);

	return {
		ok: result.ok,
		code: result.code,
		output: result.output ? result.output : '',
		error: result.error
	};
}

return {
	ccswitch: {
		list_providers: {
			args: {
				app: 'claude'
			},

			call: function(request) {
				return listProviders(request.args.app);
			}
		},

		get_provider: {
			args: {
				app: 'claude',
				provider_id: 'provider-id'
			},

			call: function(request) {
				return getProvider(request.args.app, request.args.provider_id);
			}
		},

		get_active_provider: {
			args: {
				app: 'claude'
			},

			call: function(request) {
				return getActiveProvider(request.args.app);
			}
		},

		get_runtime_status: {
			call: function() {
				return getRuntimeStatus();
			}
		},

		get_app_runtime_status: {
			args: {
				app: 'claude'
			},

			call: function(request) {
				return getAppRuntimeStatus(request.args.app);
			}
		},

		upsert_provider: {
			args: {
				app: 'claude',
				provider_id: 'provider-id',
				provider: {}
			},

			call: function(request) {
				return upsertProvider(request.args.app, request.args.provider_id, request.args.provider);
			}
		},

		upsert_active_provider: {
			args: {
				app: 'claude',
				provider: {}
			},

			call: function(request) {
				return upsertActiveProvider(request.args.app, request.args.provider);
			}
		},

		delete_provider: {
			args: {
				app: 'claude',
				provider_id: 'provider-id'
			},

			call: function(request) {
				return deleteProvider(request.args.app, request.args.provider_id);
			}
		},

		activate_provider: {
			args: {
				app: 'claude',
				provider_id: 'provider-id'
			},

			call: function(request) {
				return activateProvider(request.args.app, request.args.provider_id);
			}
		},

		restart_service: {
			call: function() {
				return restartService();
			}
		}
	}
};
